<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SpendingSmart</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-wallet-fill text-success"></i> SpendingSmart
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#features">Tính năng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#pricing">Giá cả</a>
                        </li>
                        <li class="nav-item ms-lg-3">
                            <a class="nav-link fw-bold text-success" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-success btn-sm px-4" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> Đăng ký
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer border-top py-5 mt-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-3 mb-4">
                    <h5 class="fw-bold text-success mb-3">SpendingSmart</h5>
                    <p class="text-muted small">Công cụ quản lý tài chính cá nhân thông minh và dễ sử dụng.</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Sản phẩm</h6>
                    <ul class="list-unstyled text-muted small">
                        <li><a href="#" class="text-muted text-decoration-none">Tính năng</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Giá cả</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Blog</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Công ty</h6>
                    <ul class="list-unstyled text-muted small">
                        <li><a href="#" class="text-muted text-decoration-none">Về chúng tôi</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Liên hệ</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Tuyển dụng</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h6 class="fw-bold mb-3">Pháp lý</h6>
                    <ul class="list-unstyled text-muted small">
                        <li><a href="#" class="text-muted text-decoration-none">Điều khoản</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Riêng tư</a></li>
                        <li><a href="#" class="text-muted text-decoration-none">Cookie</a></li>
                    </ul>
                </div>
            </div>
            <hr />
            <div class="row align-items-center pt-3">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted small mb-0">&copy; 2024 SpendingSmart. Tất cả quyền được bảo lưu.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#" class="text-muted me-3"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-muted me-3"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="text-muted"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>