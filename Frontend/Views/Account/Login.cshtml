@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập - SpendingSmart";
}

<div class="auth-container">
    <div class="auth-wrapper">
        <!-- Left Side - Branding -->
        <div class="auth-branding">
            <div class="auth-logo">
                <i class="bi bi-wallet-fill"></i>
            </div>
            <h1 class="auth-title">SpendingSmart</h1>
            <p class="auth-subtitle">Quản lý tài chính thông minh</p>
            
            <div class="auth-features mt-5">
                <div class="auth-feature">
                    <div class="feature-icon">📊</div>
                    <p>Quản lý chi tiêu dễ dàng</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">💡</div>
                    <p>Báo cáo chi tiết &amp; Insights</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">🔒</div>
                    <p>Bảo mật cao nhất</p>
                </div>
            </div>
        </div>

        <!-- Right Side - Form -->
        <div class="auth-form-wrapper">
            <div class="auth-form-container">
                <h2 class="mb-2">Chào mừng trở lại</h2>
                <p class="text-muted mb-4">Nhập thông tin của bạn để tiếp tục</p>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-500">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-envelope text-success"></i>
                            </span>
                            <input asp-for="Email" type="email" class="form-control border-0 ps-0" 
                                   placeholder="your@email.com" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-500">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-lock text-success"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control border-0 ps-0" 
                                   placeholder="Nhập mật khẩu" required />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label" for="rememberMe">
                                Nhớ tôi
                            </label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-success text-decoration-none fw-500 small">
                            Quên mật khẩu?
                        </a>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold mb-3">
                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                    </button>
                </form>

                <div class="divider-with-text mb-3">hoặc</div>

                <button type="button" class="btn btn-outline-secondary w-100 py-3 fw-500 mb-3">
                    <i class="bi bi-google"></i> Đăng nhập với Google
                </button>

                <p class="text-center text-muted mb-0">
                    Chưa có tài khoản? 
                    <a asp-action="Register" class="text-success text-decoration-none fw-bold">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bootstrap validation
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.querySelectorAll('.needs-validation');
                Array.prototype.slice.call(forms).forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            });
        })();
    </script>
}
