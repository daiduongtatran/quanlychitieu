@model RegisterModel

@{
    ViewData["Title"] = "Đăng ký - SpendingSmart";
}

<div class="auth-container">
    <div class="auth-wrapper">
        <!-- Left Side - Branding -->
        <div class="auth-branding">
            <div class="auth-logo">
                <i class="bi bi-wallet-fill"></i>
            </div>
            <h1 class="auth-title">SpendingSmart</h1>
            <p class="auth-subtitle">Quản lý tài chính thông minh</p>
            
            <div class="auth-features mt-5">
                <div class="auth-feature">
                    <div class="feature-icon">📊</div>
                    <p>Quản lý chi tiêu dễ dàng</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">💡</div>
                    <p>Báo cáo chi tiết &amp; Insights</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">🔒</div>
                    <p>Bảo mật cao nhất</p>
                </div>
            </div>
        </div>

        <!-- Right Side - Form -->
        <div class="auth-form-wrapper">
            <div class="auth-form-container">
                <h2 class="mb-2">Tạo tài khoản mới</h2>
                <p class="text-muted mb-4">Bắt đầu quản lý tài chính của bạn hôm nay</p>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle"></i> Vui lòng kiểm tra lại thông tin
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-500">Họ và tên</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-person text-success"></i>
                            </span>
                            <input asp-for="FullName" type="text" class="form-control border-0 ps-0" 
                                   placeholder="Nhập họ và tên" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-500">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-envelope text-success"></i>
                            </span>
                            <input asp-for="Email" type="email" class="form-control border-0 ps-0" 
                                   placeholder="your@email.com" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-500">Số điện thoại (tùy chọn)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-telephone text-success"></i>
                            </span>
                            <input asp-for="PhoneNumber" type="tel" class="form-control border-0 ps-0" 
                                   placeholder="0123456789" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-500">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-lock text-success"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control border-0 ps-0" 
                                   placeholder="Tối thiểu 6 ký tự" required id="password" />
                        </div>
                        <div class="password-strength mt-2">
                            <div class="strength-meter">
                                <div id="strengthBar" class="strength-bar"></div>
                            </div>
                            <small id="strengthText" class="text-muted">Mật khẩu yếu</small>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-500">Xác nhận mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-lock text-success"></i>
                            </span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control border-0 ps-0" 
                                   placeholder="Nhập lại mật khẩu" required />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                    </div>

                    <!-- Terms & Conditions -->
                    <div class="form-check mb-4">
                        <input asp-for="AgreeToTerms" type="checkbox" class="form-check-input" id="agreeTerms" required />
                        <label class="form-check-label" for="agreeTerms">
                            Tôi đã đọc và đồng ý với <a href="#" class="text-success text-decoration-none">Điều khoản Dịch vụ</a>
                        </label>
                        <span asp-validation-for="AgreeToTerms" class="text-danger small d-block mt-1"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold mb-3">
                        <i class="bi bi-person-plus"></i> Tạo tài khoản
                    </button>
                </form>

                <div class="divider-with-text mb-3">hoặc</div>

                <button type="button" class="btn btn-outline-secondary w-100 py-3 fw-500 mb-3">
                    <i class="bi bi-google"></i> Đăng ký với Google
                </button>

                <p class="text-center text-muted mb-0">
                    Đã có tài khoản? 
                    <a asp-action="Login" class="text-success text-decoration-none fw-bold">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Password Strength Indicator
        const passwordInput = document.getElementById('password');
        const strengthBar = document.getElementById('strengthBar');
        const strengthText = document.getElementById('strengthText');

        if (passwordInput) {
            passwordInput.addEventListener('input', function () {
                const password = this.value;
                let strength = 0;

                if (password.length >= 6) strength++;
                if (password.length >= 10) strength++;
                if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
                if (/[0-9]/.test(password)) strength++;
                if (/[^a-zA-Z0-9]/.test(password)) strength++;

                const strengthLevels = [
                    { width: '0%', color: '#dc3545', text: 'Mật khẩu yếu' },
                    { width: '25%', color: '#fd7e14', text: 'Mật khẩu trung bình' },
                    { width: '50%', color: '#ffc107', text: 'Mật khẩu tốt' },
                    { width: '75%', color: '#20c997', text: 'Mật khẩu tốt' },
                    { width: '100%', color: '#28a745', text: 'Mật khẩu mạnh' }
                ];

                const level = strengthLevels[Math.min(strength, 4)];
                strengthBar.style.width = level.width;
                strengthBar.style.backgroundColor = level.color;
                strengthText.textContent = level.text;
                strengthText.style.color = level.color;
            });
        }

        // Bootstrap validation
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.querySelectorAll('.needs-validation');
                Array.prototype.slice.call(forms).forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            });
        })();
    </script>
}
