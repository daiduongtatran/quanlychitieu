@{
    ViewData["Title"] = "Quên mật khẩu - SpendingSmart";
}

<div class="auth-container">
    <div class="auth-wrapper">
        <!-- Left Side - Branding -->
        <div class="auth-branding">
            <div class="auth-logo">
                <i class="bi bi-wallet-fill"></i>
            </div>
            <h1 class="auth-title">SpendingSmart</h1>
            <p class="auth-subtitle">Quản lý tài chính thông minh</p>
            
            <div class="auth-features mt-5">
                <div class="auth-feature">
                    <div class="feature-icon">📊</div>
                    <p>Quản lý chi tiêu dễ dàng</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">💡</div>
                    <p>Báo cáo chi tiết &amp; Insights</p>
                </div>
                <div class="auth-feature">
                    <div class="feature-icon">🔒</div>
                    <p>Bảo mật cao nhất</p>
                </div>
            </div>
        </div>

        <!-- Right Side - Form -->
        <div class="auth-form-wrapper">
            <div class="auth-form-container">
                <h2 class="mb-2">Đặt lại mật khẩu</h2>
                <p class="text-muted mb-4">Nhập email của bạn để nhận hướng dẫn đặt lại mật khẩu</p>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle"></i> @ViewBag.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (ViewBag.InfoMessage != null)
                {
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <i class="bi bi-info-circle"></i> @ViewBag.InfoMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" class="needs-validation" novalidate>
                    <div class="mb-4">
                        <label for="email" class="form-label fw-500">Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-envelope text-success"></i>
                            </span>
                            <input type="email" class="form-control border-0 ps-0" id="email" name="email"
                                   placeholder="your@email.com" required />
                        </div>
                        <small class="text-muted d-block mt-2">
                            Chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu đến email này
                        </small>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold mb-3">
                        <i class="bi bi-envelope-open"></i> Gửi hướng dẫn
                    </button>
                </form>

                <p class="text-center text-muted mb-0">
                    Nhớ mật khẩu rồi? 
                    <a asp-action="Login" class="text-success text-decoration-none fw-bold">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Bootstrap validation
        (function () {
            'use strict';
            window.addEventListener('load', function () {
                var forms = document.querySelectorAll('.needs-validation');
                Array.prototype.slice.call(forms).forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            });
        })();
    </script>
}
